DATABASE_URL=jdbc:postgresql://localhost:5432/knodeledge
DATABASE_USERNAME=knodeledge
DATABASE_PASSWORD=knodeledge

# Optional shared fallback. Use chat/embedding-specific values below when providers differ.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

OPENAI_CHAT_API_KEY=your-nvidia-llm-key
OPENAI_CHAT_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=gpt-4o-mini

OPENAI_EMBEDDING_API_KEY=your-embedding-key
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

RAG_DENSE_LIMIT=30
RAG_SPARSE_LIMIT=30
RAG_RERANK_LIMIT=50
RAG_ANSWER_CONTEXT_LIMIT=10
RAG_MIN_RERANK_SCORE=0.15
